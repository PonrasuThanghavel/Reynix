# ========================================
# DATABASE CONFIGURATION
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_db
# PostgreSQL connection string format:
# postgresql://username:password@host:port/database_name

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
# Options: development, staging, production

PORT=5000
# Server port number

API_BASE_URL=http://localhost:5000
# Base URL for API endpoints

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Secret key for signing JWT tokens (use a strong, random string)

JWT_EXPIRE=7d
# Token expiration time (e.g., 7d, 24h, 30m)

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW=15
# Time window in minutes for rate limiting

RATE_LIMIT_MAX_REQUESTS=100
# Maximum number of requests allowed per window

# ========================================
# EMAIL/SMTP CONFIGURATION (Optional)
# ========================================
SMTP_HOST=smtp.gmail.com
# SMTP server host

SMTP_PORT=587
# SMTP server port (typically 587 for TLS or 465 for SSL)

SMTP_SECURE=true
# Use TLS/SSL: true or false

SMTP_USER=your_email@gmail.com
# Email address for sending notifications

SMTP_PASS=your_app_password
# Email password or app-specific password

SMTP_FROM=noreply@reynix.com
# Default "from" email address

# ========================================
# PAYMENT GATEWAY CONFIGURATION (Optional)
# ========================================
PAYMENT_GATEWAY_KEY=your_payment_gateway_api_key
# API key for payment gateway integration

PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret
# Secret key for payment gateway

# ========================================
# LOGGING CONFIGURATION (Optional)
# ========================================
LOG_LEVEL=info
# Log level: error, warn, info, debug

LOG_FILE=logs/app.log
# Path to log file

# ========================================
# FRONTEND CONFIGURATION
# ========================================
FRONTEND_URL=http://localhost:5173
# Frontend application URL for CORS

# ========================================
# SECURITY CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Comma-separated list of allowed origins

# ========================================
# DEVELOPMENT TOOLS
# ========================================
DEBUG=false
# Enable debug mode
