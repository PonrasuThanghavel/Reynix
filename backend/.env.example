# ========================================
# REYNIX BACKEND ENVIRONMENT EXAMPLE
# Code-accurate variables derived from backend source
# ========================================

# ========================================
# DATABASE CONFIGURATION
# Used by: backend/config/database.js
# ========================================
DB_NAME=ecommerce_db
DB_USER=ecom_user
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ========================================
# SERVER CONFIGURATION
# Used by: backend/server.js, backend/config/database.js,
#          backend/utils/errorHandler.js
# ========================================
NODE_ENV=development
# Options: development, production

PORT=5000
# Express server port

# ========================================
# JWT AUTHENTICATION
# Used by: backend/services/userService.js,
#          backend/utils/authMiddleware.js
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
# Required: app auth breaks if this is missing

JWT_EXPIRES_IN=7d
# Examples: 7d, 24h, 30m
